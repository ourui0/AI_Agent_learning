   },
   "cell_type": "code",
   "source": [
    "# 真实值\n",
    "target = torch.tensor([[1], [0], [0]], dtype=torch.float32)\n",
    "# 预测值\n",
    "input = torch.randn((3, 1))\n",
    "prediction = torch.sigmoid(input)\n",
    "# 实例化损失函数\n",
    "loss = nn.BCELoss()\n",
    "print(loss(prediction, target))"
   ],
